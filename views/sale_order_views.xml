<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_plugit_rate" model="ir.ui.view">
        <field name="name">sale.order.form.plugit.rate</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- ── Make Order Date editable on confirmed orders ── -->
            <xpath expr="//field[@name='date_order'][@nolabel='1'][not(@groups)]" position="attributes">
                <attribute name="readonly">state == 'cancel' or locked</attribute>
            </xpath>

            <!-- ── order_details: pricelist rate info ────────────────────── -->
            <xpath expr="//group[@name='order_details']/field[@name='payment_term_id']" position="before">
                <field name="plugit_pricelist_currency_id" invisible="1"/>
                <field
                    name="plugit_base_pricelist_id"
                    groups="base.group_no_one"
                    readonly="1"
                    options="{'no_open': True}"
                    invisible="not plugit_base_pricelist_id"/>
                <field
                    name="plugit_rate_label"
                    readonly="1"
                    invisible="not plugit_rate_label"/>
            </xpath>

        </field>
    </record>
</odoo>
